# Local repository root used by the worker.
LOCAL_REPO_BASE_DIR=$HOME/.repooperator/repos

# OpenAI-compatible model API settings.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini

# Optional GitLab settings for clone, push, and merge request flows.
GITLAB_BASE_URL=https://gitlab.example.com
GITLAB_TOKEN=replace-me

# Optional tuning values.
REPOOPERATOR_COMMAND_TIMEOUT_SECONDS=30
REPOOPERATOR_GIT_CLONE_TIMEOUT_SECONDS=300
REPOOPERATOR_GIT_FETCH_TIMEOUT_SECONDS=120
REPOOPERATOR_GIT_PUSH_TIMEOUT_SECONDS=180
REPOOPERATOR_MODEL_REQUEST_TIMEOUT_SECONDS=60
